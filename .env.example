# ── Firebase project config (from Firebase Console → Project Settings → Your Apps)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# ── Email address of the admin Firebase account
VITE_ADMIN_EMAIL=admin@yourdomain.com

# ── Backend: path to Firebase service account JSON inside the container
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=service-account.json

# ── Same admin email for backend route protection
ADMIN_EMAIL=admin@yourdomain.com

